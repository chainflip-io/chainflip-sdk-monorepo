{
  "name": "lending",
  "version": "1.0.0",
  "description": "Lending service backend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm clean && prisma generate && tsc && tsc-alias",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/packages/lending/src/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "eslint:check": "pnpm eslint --max-warnings 0 './**/*.ts'",
    "prettier:base": "prettier ./** --ignore-path=../../.prettierignore",
    "prettier:check": "pnpm prettier:base --check",
    "prettier:write": "pnpm prettier:base --write",
    "postinstall": "prisma generate",
    "generate:models": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "migrate:reset": "prisma migrate reset",
    "graphql:codegen": "graphql-codegen --config .graphqlrc.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "pg": "^8.16.2",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "graphql-request": "^7.2.0",
    "winston": "^3.17.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/client-preset": "^4.8.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@types/express": "^5.0.3",
    "graphql": "^16.11.0",
    "prisma": "^7.4.2"
  },
  "engines": {
    "node": "24.13.0",
    "pnpm": ">=10"
  }
}
