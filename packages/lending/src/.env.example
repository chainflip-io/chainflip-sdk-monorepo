# Service flags
START_PROCESSOR=TRUE
START_HTTP_SERVICE=TRUE

# Database
DATABASE_URL=postgresql://lending_user:lending_password@localhost:5432/lending_db

# Server
LENDING_APP_PORT=3000

# Indexer (replace with actual URL)
INGEST_GATEWAY_URL=https://indexer.staging.chainflip.io/graphql

# Processor config
PROCESSOR_BATCH_SIZE=50
PROCESSOR_TRANSACTION_TIMEOUT=10000

# Logging
NODE_ENV=development
LOG_LEVEL=info